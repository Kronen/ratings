{
  "manifest_version": 3,
  "name": "FaRatings",
  "version": "1.0.0",
  "description": "Overlay FilmAffinity ratings on Netflix title cards",
  "permissions": ["storage"],
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self'; connect-src https://www.filmaffinity.com"
  },
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://www.filmaffinity.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
